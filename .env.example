# trainsight — environment variables (TR-DEPLOY-002)
# Copy to .env and populate. Never commit .env.

# Required
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Bare numeric reasoning engine ID only (last path segment) - NOT the full resource
# path. deploy_agents.sh prints and extracts this after deploy; see deployment_metadata.json.
CHALLENGER_AGENT_RUNTIME_ID=challenger-numeric-id
BRIEFING_AGENT_RUNTIME_ID=briefing-numeric-id

# Optional (defaults shown)
VERTEX_AI_LOCATION=us-central1
# Region the Agent Runtime (reasoningEngines) resource actually lives in - independent
# of VERTEX_AI_LOCATION, which governs this service's own Cloud Run region and the
# deployed agents' Gemini call region. agents-cli currently deploys to us-east1.
AGENT_RUNTIME_LOCATION=us-east1
VERTEX_AI_MODEL=gemini-2.5-flash-lite
LLM_PROVIDER=vertexai
SUBMISSION_WINDOW_OPEN=true
PORT=8080
AUDIT_LOG_PATH=data/audit.log
GOOGLE_GENAI_USE_VERTEXAI=true
SESSION_SECRET_KEY=  # Leave blank to autogenerate on deploy, or set a secure random string

